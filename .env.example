# Copy to .env for local dev. Never commit .env — real values go in Coolify's
# env var UI for staging/production (SPEC.md §1).

DATABASE_URL="postgresql://localhost:5432/quest_ct_forward_planner_dev"

# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-secret"

# Read from an env var so the domain can change per-environment without a code change.
NEXTAUTH_URL="http://localhost:3000"

# TMS — the identity source for login (SPEC.md §13.1). Read-only: this app must never
# write to it. Ask an admin for the correct connection string for your environment.
MYSQL_AUTH_DATABASE_URL="mysql://root@127.0.0.1:3306/questmedical_development_2023"
